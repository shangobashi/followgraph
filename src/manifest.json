{
  "manifest_version": 3,
  "name": "FollowGraph",
  "version": "1.0.0",
  "description": "Client-side Following Exporter for X/Twitter. No servers, no tracking.",
  "author": "Shango Bashi",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["https://twitter.com/*", "https://x.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}
